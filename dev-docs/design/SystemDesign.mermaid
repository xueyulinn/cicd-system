graph TB
    subgraph DevMachine["Developer Machine"]
        subgraph UserLayer["User Interface Layer"]
            CLI["CLI Client<br/>(cicd command)"]
            Git["Git Repository<br/>(.pipelines/*.yaml)"]
        end
        
        subgraph APILayer["API Layer"]
            Gateway["API Gateway<br/>(Port 8000)<br/>REST/gRPC Router"]
        end
        
        subgraph Controller["Controller Service (Core Orchestration)"]
            ValService["Validation Service<br/>(Port 8001)<br/>- YAML Parsing<br/>- Schema Validation<br/>- Cycle Detection"]
            ExecService["Execution Service<br/>(Port 8002)<br/>- Pipeline Orchestrator<br/>- Job Scheduler<br/>- State Management"]
            ReportService["Reporting Service<br/>(Port 8004)<br/>- Query Aggregation<br/>"]
        end
        
        subgraph WorkerLayer["Worker Layer"]
            WorkerService["Worker Service<br/>(Port 8003)<br/>- Job Executor Pool<br/>- Container Management<br/>- Log Collection"]
        end
        
        subgraph DataLayer["Data Layer"]
           %% Redis["Redis Cache<br/>(Port 6379)<br/>- Validation Results<br/>- Session Data"]
            DB["PostgreSQL Database<br/>(Port 5432)<br/>- pipeline_runs<br/>- stages<br/>- jobs<br/>- execution_logs"]
        end
        
        subgraph RuntimeLayer["Container Runtime"]
            Docker["Docker Engine<br/>- Image Management<br/>- Container Lifecycle"]
        end
    end
    
    %% User Layer Connections
    CLI -->|1. Read Config| Git
    CLI -->|2. HTTP/gRPC Request| Gateway
    
    %% API Gateway Routing
    Gateway -->|3a. POST /validate| ValService
    Gateway -->|3b. POST /run| ExecService
    Gateway -->|3c. GET /report| ReportService
    Gateway -.->|Response| CLI
    
    %% Validation Service
    %% ValService -->|4a. Cache Validation| Redis
    %% Redis -.->|Cached Result| ValService
    ValService -->|4b. Validation Response| Gateway
    
    %% Execution Service Workflow
    ExecService -->|5a. Validate Pipeline| ValService
    ValService -.->|Valid/Invalid| ExecService
    ExecService -->|5b. Create Pipeline Run| DB
    DB -.->|run_id| ExecService
    ExecService -->|5c. POST /execute| WorkerService
    WorkerService -.->|Job Status Updates| ExecService
    ExecService -->|5d. Update Status| DB
    
    %% Worker Service Operations
    WorkerService -->|6a. Pull Image| Docker
    WorkerService -->|6b. Create/Start Container| Docker
    Docker -.->|Container Logs| WorkerService
    WorkerService -->|6c. Store Logs| DB
    Docker -.->|Exit Code| WorkerService
    WorkerService -->|6d. Cleanup Container| Docker
    
    %% Reporting Service
    ReportService -->|7. Query Execution Data| DB
    DB -.->|Aggregated Results| ReportService
    ReportService -.->|Formatted Report| Gateway
    
    %% Styling
    style CLI fill:#e1b2e1,stroke:#01379b,stroke-width:2px
    style Gateway fill:#ff24e1,stroke:#f57f17,stroke-width:2px
    style ValService fill:#a3a5e9,stroke:#2e7d32,stroke-width:2px
    style ExecService fill:#f1a4f4,stroke:#f9a825,stroke-width:2px
    style WorkerService fill:#c2a5f5,stroke:#6a1b9a,stroke-width:2px
    style ReportService fill:#ff55bc,stroke:#d84315,stroke-width:2px
 %%  style Redis fill:#a3a5e9,stroke:#c62828,stroke-width:2px
    style DB fill:#a3a5e9,stroke:#b71c1c,stroke-width:2px
    style Docker fill:#a1b6a2,stroke:#4a148c,stroke-width:2px
    style Git fill:#e327fa,stroke:#006064,stroke-width:2px
    
    %% Layer Styling
    style UserLayer fill:#f5f5f5,stroke:#424242,stroke-width:1px,stroke-dasharray: 5 5
    style APILayer fill:#fafafa,stroke:#424242,stroke-width:1px,stroke-dasharray: 5 5
    style Controller fill:#fff8e1,stroke:#ff6f00,stroke-width:2px
    style WorkerLayer fill:#f1f8e9,stroke:#33691e,stroke-width:1px,stroke-dasharray: 5 5
    style DataLayer fill:#fce4ec,stroke:#880e4f,stroke-width:1px,stroke-dasharray: 5 5
    style RuntimeLayer fill:#ede7f6,stroke:#311b92,stroke-width:1px,stroke-dasharray: 5 5