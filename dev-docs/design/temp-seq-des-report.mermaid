sequenceDiagram
    actor Dev as Developer
    participant CLI as CLI Client
    participant Ctrl as Controller Service
    participant Rep as Report Generator
    participant DB as PostgreSQL Database

    Dev->>CLI: cicd report --pipeline default --run 1 --stage build
    
    CLI->>Ctrl: Generate report (pipeline='default', run=1, stage='build')
    
    Ctrl->>Rep: Request report (pipeline, run, stage)
    
    Rep->>DB: SELECT * FROM pipeline_runs<br/>WHERE name='default' AND run_no=1
    DB-->>Rep: pipeline_run record<br/>(run_id, start_time, end_time, status,<br/>git_hash, git_branch, git_repo)
    
    alt Pipeline run not found
        Rep->>Ctrl: Error: Pipeline run not found
        Ctrl->>CLI: Error message
        CLI->>Dev: Error: No run #1 found for pipeline 'default'
    else Pipeline run found
        Rep->>DB: SELECT * FROM stages<br/>WHERE run_id={run_id} AND name='build'
        DB-->>Rep: stage record<br/>(stage_id, start_time, end_time, status)
        
        alt Stage not found
            Rep->>Ctrl: Error: Stage not found
            Ctrl->>CLI: Error message
            CLI->>Dev: Error: Stage 'build' not found in pipeline 'default' run #1
        else Stage found
            Rep->>DB: SELECT * FROM jobs<br/>WHERE stage_id={stage_id}<br/>ORDER BY start_time
            DB-->>Rep: List of job records<br/>(name, start_time, end_time, status)
            
            Rep->>Rep: Format report as YAML
            Rep->>Rep: Build YAML structure with<br/>pipeline info, stage info, jobs list
            
            Rep->>Ctrl: Report YAML string
            Ctrl->>CLI: Report content
            CLI->>Dev: Display report
            
            Note over Dev: pipeline:<br/>  name: default<br/>  run-no: 1<br/>  status: success<br/>  stage:<br/>    - name: build<br/>      status: success<br/>      jobs:<br/>        - name: compile<br/>          status: success
        end
    end